@page "/"

<PageTitle>Product Data Manager</PageTitle>

<div class="pdm-animate-in">
    <div class="pdm-hero">
        <div class="pdm-hero-icon">
            <FluentIcon Value="@(new Icons.Regular.Size32.Box())" Color="Color.Custom" CustomColor="#fff" />
        </div>
        <h1>Product Data Manager</h1>
        <p>
            Your centralized hub for managing the e-commerce product catalog.
            Organize categories, manage products, and configure attributes with ease.
        </p>
    </div>

    <div class="pdm-dashboard-grid">
        <a href="/categories" class="pdm-dashboard-card" style="--card-accent: #6366f1;">
            <div style="width: 44px; height: 44px; border-radius: var(--pdm-radius-md); display: flex; align-items: center; justify-content: center; background: rgba(99,102,241,0.12); color: #818cf8;">
                <FluentIcon Value="@(new Icons.Regular.Size24.FolderMultiple())" Color="Color.Custom" CustomColor="currentColor" />
            </div>
            <div>
                <h3 style="margin: 0;">Categories</h3>
                <p style="margin: 0; font-size: 0.825rem; color: var(--pdm-text-secondary);">Organize products into a hierarchical tree structure with unlimited nesting depth.</p>
            </div>
            <span style="font-size: 0.8rem; font-weight: 500; color: var(--pdm-primary-light); margin-top: auto;">Manage categories →</span>
        </a>

        <a href="/products" class="pdm-dashboard-card" style="--card-accent: #06b6d4;">
            <div style="width: 44px; height: 44px; border-radius: var(--pdm-radius-md); display: flex; align-items: center; justify-content: center; background: rgba(6,182,212,0.12); color: #22d3ee;">
                <FluentIcon Value="@(new Icons.Regular.Size24.Box())" Color="Color.Custom" CustomColor="currentColor" />
            </div>
            <div>
                <h3 style="margin: 0;">Products</h3>
                <p style="margin: 0; font-size: 0.825rem; color: var(--pdm-text-secondary);">Create and manage your product catalog with SKUs, pricing, and category assignments.</p>
            </div>
            <span style="font-size: 0.8rem; font-weight: 500; color: var(--pdm-primary-light); margin-top: auto;">Manage products →</span>
        </a>

        <a href="/description-types" class="pdm-dashboard-card" style="--card-accent: #10b981;">
            <div style="width: 44px; height: 44px; border-radius: var(--pdm-radius-md); display: flex; align-items: center; justify-content: center; background: rgba(16,185,129,0.12); color: #10b981;">
                <FluentIcon Value="@(new Icons.Regular.Size24.TextDescription())" Color="Color.Custom" CustomColor="currentColor" />
            </div>
            <div>
                <h3 style="margin: 0;">Description Types</h3>
                <p style="margin: 0; font-size: 0.825rem; color: var(--pdm-text-secondary);">Define structured description schemas with configurable value sets for product details.</p>
            </div>
            <span style="font-size: 0.8rem; font-weight: 500; color: var(--pdm-primary-light); margin-top: auto;">Manage descriptions →</span>
        </a>

        <a href="/attribute-types" class="pdm-dashboard-card" style="--card-accent: #f59e0b;">
            <div style="width: 44px; height: 44px; border-radius: var(--pdm-radius-md); display: flex; align-items: center; justify-content: center; background: rgba(245,158,11,0.12); color: #f59e0b;">
                <FluentIcon Value="@(new Icons.Regular.Size24.Tag())" Color="Color.Custom" CustomColor="currentColor" />
            </div>
            <div>
                <h3 style="margin: 0;">Attribute Types</h3>
                <p style="margin: 0; font-size: 0.825rem; color: var(--pdm-text-secondary);">Configure custom attribute schemas with key-value pairs for product specifications.</p>
            </div>
            <span style="font-size: 0.8rem; font-weight: 500; color: var(--pdm-primary-light); margin-top: auto;">Manage attributes →</span>
        </a>
    </div>
</div>
