@page "/description-types"
@using MassTransit

@inject IRequestClient<GetDescriptionTypes> DescriptionTypesClient
@inject IRequestClient<CreateDescriptionType> CreateClient
@inject IRequestClient<UpdateDescriptionType> UpdateClient
@inject IRequestClient<DeleteDescriptionType> DeleteClient
@inject IRequestClient<AddDescriptionValue> AddValueClient
@inject IRequestClient<DeleteDescriptionValue> DeleteValueClient
@inject IToastService ToastService

<PageTitle>Description Types — Product Data Manager</PageTitle>

<div class="pdm-animate-in">
    <div class="pdm-page-header">
        <div>
            <h1>
                <span class="pdm-page-header-icon" style="background: rgba(16, 185, 129, 0.12);">
                    <FluentIcon Value="@(new Icons.Regular.Size20.TextDescription())" Color="Color.Custom" CustomColor="#10b981" />
                </span>
                Description Types
            </h1>
            <div style="font-size: 0.85rem; color: var(--pdm-text-muted); margin-top: 2px;">Define structured description schemas with configurable value sets</div>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="OpenCreateDialog">
            Add Description Type
        </FluentButton>
    </div>

    @if (_loading)
    {
        <div class="pdm-loading-state">
            <FluentProgressRing />
            <span>Loading description types…</span>
        </div>
    }
    else if (!_descriptionTypes.Any())
    {
        <div class="pdm-empty-state">
            <div class="pdm-empty-state__icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.TextDescription())" Color="Color.Custom" CustomColor="#64748b" />
            </div>
            <p>No description types yet.</p>
            <p>Click "Add Description Type" to start defining product descriptions.</p>
        </div>
    }
    else
    {
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
            @foreach (var dt in _descriptionTypes)
            {
                <div class="pdm-section-card">
                    <div class="pdm-section-card__header">
                        <div class="pdm-section-card__body">
                            <h3 class="pdm-section-card__title">@dt.Name</h3>
                            @if (!string.IsNullOrEmpty(dt.Description))
                            {
                                <div class="pdm-section-card__description">@dt.Description</div>
                            }
                        </div>
                        <div class="pdm-section-card__actions">
                            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())" Title="Edit" OnClick="@(() => OpenEditDialog(dt))" />
                            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" Title="Delete" OnClick="@(() => ConfirmDelete(dt))" />
                        </div>
                    </div>

                    <div class="pdm-section-card__content">
                        <div class="pdm-tags-container">
                            @foreach (var value in dt.Values)
                            {
                                <span class="pdm-tag">
                                    @value.Value
                                    <button class="pdm-tag-remove" title="Remove value" @onclick="@(() => ConfirmDeleteValue(value.Id))">
                                        <FluentIcon Value="@(new Icons.Regular.Size12.Dismiss())" Color="Color.Custom" CustomColor="currentColor" />
                                    </button>
                                </span>
                            }
                            @if (!dt.Values.Any())
                            {
                                <span class="pdm-no-items-text">No values defined yet.</span>
                            }
                        </div>

                            <div class="pdm-inline-form">
                                <FluentTextField @bind-Value="_newValueText" Placeholder="New value..." Style="flex: 1;" />
                                <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.Add())" OnClick="@(() => HandleAddValue(dt.Id))">Add</FluentButton>
                            </div>

                            @* Delete value buttons get confirm *@
                    </div>
                </div>
            }
        </FluentStack>
    }
</div>

<FluentDialog @bind-Hidden="@_dialogHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(_editing is not null ? new Icons.Regular.Size20.Edit() : (Icon)new Icons.Regular.Size20.Add())"
                        Color="Color.Custom" CustomColor="#10b981" />
            <h3>@(_editing is not null ? "Edit Description Type" : "New Description Type")</h3>
        </div>
        <div class="pdm-dialog-subtitle">
            @(_editing is not null ? "Update the description type details" : "Define a new description type for products")
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Class="pdm-dialog-form">
            <FluentTextField @bind-Value="_formName" Label="Name" Required="true" Style="width: 100%;" Placeholder="e.g. Technical Specs, Features..." />
            <FluentTextArea @bind-Value="_formDescription" Label="Description" Rows="2" Style="width: 100%;" Placeholder="Optional description..." />
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _dialogHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="HandleSave" Loading="_saving" IconStart="@(new Icons.Regular.Size16.Checkmark())">
            @(_editing is not null ? "Update" : "Create")
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Confirm Delete Type Dialog *@
<FluentDialog @bind-Hidden="@_confirmDeleteHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(new Icons.Regular.Size20.Warning())" Color="Color.Custom" CustomColor="#ef4444" />
            <h3>Confirm Deletion</h3>
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <p>Are you sure you want to delete the description type <strong>@_typeToDelete?.Name</strong>?</p>
        <p style="font-size: 0.85rem; color: var(--pdm-text-muted);">This will also remove all associated values. This action cannot be undone.</p>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _confirmDeleteHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" Style="--accent-fill-rest: #ef4444; --accent-fill-hover: #dc2626;"
                      OnClick="HandleDelete" Loading="_deleting"
                      IconStart="@(new Icons.Regular.Size16.Delete())">
            Delete
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Confirm Delete Value Dialog *@
<FluentDialog @bind-Hidden="@_confirmDeleteValueHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(new Icons.Regular.Size20.Warning())" Color="Color.Custom" CustomColor="#ef4444" />
            <h3>Confirm Value Deletion</h3>
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <p>Are you sure you want to delete this description value?</p>
        <p style="font-size: 0.85rem; color: var(--pdm-text-muted);">Products using this value will lose the association.</p>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _confirmDeleteValueHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" Style="--accent-fill-rest: #ef4444; --accent-fill-hover: #dc2626;"
                      OnClick="HandleDeleteValue" Loading="_deletingValue"
                      IconStart="@(new Icons.Regular.Size16.Delete())">
            Delete
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<DescriptionTypeDto> _descriptionTypes = [];
    private bool _loading = true;
    private bool _dialogHidden = true;
    private bool _saving;
    private string _formName = string.Empty;
    private string? _formDescription;
    private string _newValueText = string.Empty;
    private DescriptionTypeDto? _editing;

    // Confirm delete type
    private bool _confirmDeleteHidden = true;
    private bool _deleting;
    private DescriptionTypeDto? _typeToDelete;

    // Confirm delete value
    private bool _confirmDeleteValueHidden = true;
    private bool _deletingValue;
    private Guid _valueToDeleteId;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        var response = await DescriptionTypesClient.GetResponse<GetDescriptionTypesResult>(new GetDescriptionTypes());
        _descriptionTypes = response.Message.DescriptionTypes;
        _loading = false;
    }

    private void OpenCreateDialog() { _editing = null; _formName = string.Empty; _formDescription = null; _dialogHidden = false; }

    private void OpenEditDialog(DescriptionTypeDto dt) { _editing = dt; _formName = dt.Name; _formDescription = dt.Description; _dialogHidden = false; }

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(_formName)) return;
        _saving = true;
        if (_editing is not null)
        {
            var response = await UpdateClient.GetResponse<UpdateDescriptionTypeResult>(new UpdateDescriptionType(_editing.Id, _formName, _formDescription));
            if (response.Message.Success)
                ToastService.ShowSuccess("Description type updated.");
            else
                ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to update description type.");
        }
        else
        {
            var response = await CreateClient.GetResponse<CreateDescriptionTypeResult>(new CreateDescriptionType(_formName, _formDescription));
            if (response.Message.Success)
                ToastService.ShowSuccess("Description type created.");
            else
                ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to create description type.");
        }
        _saving = false; _dialogHidden = true; await LoadData();
    }

    private void ConfirmDelete(DescriptionTypeDto dt)
    {
        _typeToDelete = dt;
        _confirmDeleteHidden = false;
    }

    private async Task HandleDelete()
    {
        if (_typeToDelete is null) return;
        _deleting = true;
        var response = await DeleteClient.GetResponse<DeleteDescriptionTypeResult>(new DeleteDescriptionType(_typeToDelete.Id));
        if (response.Message.Success)
        {
            ToastService.ShowSuccess($"'{_typeToDelete.Name}' deleted.");
            await LoadData();
        }
        else
        {
            ToastService.ShowError(response.Message.ErrorMessage ?? "Cannot delete description type.");
        }
        _deleting = false;
        _confirmDeleteHidden = true;
    }

    private async Task HandleAddValue(Guid descriptionTypeId)
    {
        if (string.IsNullOrWhiteSpace(_newValueText)) return;
        var response = await AddValueClient.GetResponse<AddDescriptionValueResult>(new AddDescriptionValue(descriptionTypeId, _newValueText));
        if (response.Message.Success)
            ToastService.ShowSuccess("Value added.");
        else
            ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to add value.");
        _newValueText = string.Empty; await LoadData();
    }

    private void ConfirmDeleteValue(Guid valueId)
    {
        _valueToDeleteId = valueId;
        _confirmDeleteValueHidden = false;
    }

    private async Task HandleDeleteValue()
    {
        _deletingValue = true;
        var response = await DeleteValueClient.GetResponse<DeleteDescriptionValueResult>(new DeleteDescriptionValue(_valueToDeleteId));
        if (response.Message.Success)
        {
            ToastService.ShowSuccess("Value deleted.");
            await LoadData();
        }
        else
        {
            ToastService.ShowError(response.Message.ErrorMessage ?? "Cannot delete value — it may be used by products.");
        }
        _deletingValue = false;
        _confirmDeleteValueHidden = true;
    }
}
