@page "/products"
@using MassTransit
@using ProductDataManager.Infrastructure.Messages.Products
@using ProductDataManager.Infrastructure.Messages.Categories

@inject IRequestClient<GetProducts> ProductsClient
@inject IRequestClient<CreateProduct> CreateProductClient
@inject IRequestClient<UpdateProduct> UpdateProductClient
@inject IRequestClient<DeleteProduct> DeleteProductClient
@inject IRequestClient<GetRootCategories> CategoriesClient
@inject IToastService ToastService

<PageTitle>Products — Product Data Manager</PageTitle>

<div class="pdm-animate-in">
    <div class="pdm-page-header">
        <div>
            <h1>
                <span class="pdm-page-header-icon" style="background: rgba(6, 182, 212, 0.12);">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Box())" Color="Color.Custom" CustomColor="#22d3ee" />
                </span>
                Products
            </h1>
            <div style="font-size: 0.85rem; color: var(--pdm-text-muted); margin-top: 2px;">Manage your product catalog — pricing, SKUs, and assignments</div>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="OpenCreateDialog">
            Add Product
        </FluentButton>
    </div>

    <div style="background: var(--pdm-bg-card); border: 1px solid var(--pdm-border); border-radius: var(--pdm-radius-lg); overflow: hidden;">
        @if (_loading)
        {
            <div style="display: flex; flex-direction: column; align-items: center; padding: 48px; gap: 16px; color: var(--pdm-text-muted);">
                <FluentProgressRing />
                <span>Loading products…</span>
            </div>
        }
        else if (!_products.Any())
        {
            <div style="text-align: center; padding: 48px; color: var(--pdm-text-muted);">
                <div style="width: 56px; height: 56px; margin: 0 auto 16px; background: var(--pdm-bg-subtle); border-radius: var(--pdm-radius-lg); display: flex; align-items: center; justify-content: center; opacity: 0.5;">
                    <FluentIcon Value="@(new Icons.Regular.Size24.Box())" Color="Color.Custom" CustomColor="#64748b" />
                </div>
                <p style="margin: 0;">No products yet.</p>
                <p style="font-size: 0.8rem; margin-top: 4px;">Click "Add Product" to create your first one.</p>
            </div>
        }
        else
        {
            <div style="padding: 4px;">
                <FluentDataGrid Items="@_products.AsQueryable()" Pagination="@_pagination" TGridItem="ProductDto"
                                Style="width: 100%;" GridTemplateColumns="1fr 0.6fr 0.5fr 0.5fr 0.4fr 0.5fr">
                    <PropertyColumn Property="@(p => p.Name)" Title="Name" Sortable="true" />
                    <PropertyColumn Property="@(p => p.Sku)" Title="SKU" Sortable="true" />
                    <PropertyColumn Property="@(p => p.CategoryName)" Title="Category" />
                    <TemplateColumn Title="Price">
                        <span style="font-weight: 500; font-variant-numeric: tabular-nums;">@context.Price.ToString("C")</span>
                    </TemplateColumn>
                    <TemplateColumn Title="Status">
                        @if (context.IsActive)
                        {
                            <span style="display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; border-radius: 100px; font-size: 0.75rem; font-weight: 500; background: rgba(16,185,129,0.12); color: var(--pdm-success);">
                                <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor;"></span> Active
                            </span>
                        }
                        else
                        {
                            <span style="display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; border-radius: 100px; font-size: 0.75rem; font-weight: 500; background: rgba(100,116,139,0.12); color: var(--pdm-text-muted);">
                                <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor;"></span> Inactive
                            </span>
                        }
                    </TemplateColumn>
                    <TemplateColumn Title="">
                        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 2px;">
                            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())" Title="Edit" OnClick="@(() => OpenEditDialog(context))" />
                            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" Title="Delete" OnClick="@(() => HandleDelete(context))" />
                        </FluentStack>
                    </TemplateColumn>
                </FluentDataGrid>
            </div>
            <div style="padding: 12px 16px; border-top: 1px solid var(--pdm-border);">
                <FluentPaginator State="@_pagination" />
            </div>
        }
    </div>
</div>

<FluentDialog @bind-Hidden="@_dialogHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
            <FluentIcon Value="@(_editingProduct is not null ? new Icons.Regular.Size20.Edit() : (Icon)new Icons.Regular.Size20.Add())"
                        Color="Color.Custom" CustomColor="#22d3ee" />
            <h3 style="margin: 0;">@(_editingProduct is not null ? "Edit Product" : "New Product")</h3>
        </div>
        <div style="font-size: 0.825rem; color: var(--pdm-text-muted); margin-bottom: 16px;">
            @(_editingProduct is not null ? "Update product information" : "Fill in the details for the new product")
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px; min-width: 480px;">
            <FluentTextField @bind-Value="_formName" Label="Name" Required="true" Style="width: 100%;" Placeholder="e.g. Wireless Headphones" />
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 12px;">
                <FluentTextField @bind-Value="_formSku" Label="SKU" Required="true" Style="flex: 1;" Placeholder="e.g. WH-1000XM5" />
                <FluentNumberField @bind-Value="_formPrice" Label="Price" Min="0" Step="0.01m" Style="flex: 1;" />
            </FluentStack>
            <FluentTextArea @bind-Value="_formDescription" Label="Description" Rows="3" Style="width: 100%;" Placeholder="Product description..." />
            @if (_editingProduct is not null)
            {
                <FluentCheckbox @bind-Value="_formIsActive" Label="Active" />
            }
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _dialogHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="HandleSave" Loading="_saving"
                      IconStart="@(new Icons.Regular.Size16.Checkmark())">
            @(_editingProduct is not null ? "Update" : "Create")
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<ProductDto> _products = [];
    private PaginationState _pagination = new() { ItemsPerPage = 20 };
    private bool _loading = true;
    private bool _dialogHidden = true;
    private bool _saving;
    private string _formName = string.Empty;
    private string _formSku = string.Empty;
    private string? _formDescription;
    private decimal _formPrice;
    private bool _formIsActive = true;
    private Guid _formCategoryId;
    private ProductDto? _editingProduct;

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        _loading = true;
        var response = await ProductsClient.GetResponse<GetProductsResult>(new GetProducts());
        _products = response.Message.Products;
        _loading = false;
    }

    private void OpenCreateDialog()
    {
        _editingProduct = null; _formName = string.Empty; _formSku = string.Empty;
        _formDescription = null; _formPrice = 0; _formIsActive = true;
        _dialogHidden = false;
    }

    private void OpenEditDialog(ProductDto product)
    {
        _editingProduct = product; _formName = product.Name; _formSku = product.Sku;
        _formDescription = product.Description; _formPrice = product.Price;
        _formIsActive = product.IsActive; _formCategoryId = product.CategoryId;
        _dialogHidden = false;
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(_formName) || string.IsNullOrWhiteSpace(_formSku)) return;
        _saving = true;

        if (_editingProduct is not null)
        {
            var response = await UpdateProductClient.GetResponse<UpdateProductResult>(
                new UpdateProduct(_editingProduct.Id, _formName, _formSku, _formDescription, _formPrice, _formCategoryId, _formIsActive));
            if (response.Message.Success) ToastService.ShowSuccess("Product updated successfully.");
            else ToastService.ShowError("Failed to update product.");
        }
        else
        {
            var response = await CreateProductClient.GetResponse<CreateProductResult>(
                new CreateProduct(_formName, _formSku, _formDescription, _formPrice, _formCategoryId));
            if (response.Message.Id != Guid.Empty) ToastService.ShowSuccess("Product created successfully.");
            else ToastService.ShowError("Failed to create product.");
        }

        _saving = false; _dialogHidden = true;
        await LoadProducts();
    }

    private async Task HandleDelete(ProductDto product)
    {
        var response = await DeleteProductClient.GetResponse<DeleteProductResult>(new DeleteProduct(product.Id));
        if (response.Message.Success)
        { ToastService.ShowSuccess($"Product '{product.Name}' deleted."); await LoadProducts(); }
        else ToastService.ShowError("Failed to delete product.");
    }
}
