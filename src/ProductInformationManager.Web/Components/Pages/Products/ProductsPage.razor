@* @page "/products" *@
@* @using MassTransit *@
@* *@
@* @inject IRequestClient<GetProducts> ProductsClient *@
@* @inject IRequestClient<CreateProduct> CreateProductClient *@
@* @inject IRequestClient<UpdateProductDetails> UpdateDetailsClient *@
@* @inject IRequestClient<ChangeProductCategory> ChangeCategoryClient *@
@* @inject IRequestClient<ChangeProductStatus> ChangeStatusClient *@
@* @inject IRequestClient<DeleteProduct> DeleteProductClient *@
@* @inject IRequestClient<SearchCategory> CategoriesClient *@
@* @inject IRequestClient<GetCategoryDescriptions> CategoryDescriptionsClient *@
@* @inject IRequestClient<SetProductDescription> SetDescriptionClient *@
@* @inject IToastService ToastService *@
@* *@
@* <PageTitle>Products — Product Data Manager</PageTitle> *@
@* *@
@* <div class="pdm-animate-in"> *@
@*     <div class="pdm-page-header"> *@
@*         <div> *@
@*             <h1> *@
@*                 <span class="pdm-page-header-icon" style="background: rgba(6, 182, 212, 0.12);"> *@
@*                     <FluentIcon Value="@(new Icons.Regular.Size20.Box())" Color="Color.Custom" CustomColor="#22d3ee" /> *@
@*                 </span> *@
@*                 Products *@
@*             </h1> *@
@*             <div style="font-size: 0.85rem; color: var(--pdm-text-muted); margin-top: 2px;">Manage your product catalog — pricing, SKUs, and assignments</div> *@
@*         </div> *@
@*         <FluentButton Appearance="Appearance.Accent" *@
@*                       IconStart="@(new Icons.Regular.Size16.Add())" *@
@*                       OnClick="OpenCreateDialog"> *@
@*             Add Product *@
@*         </FluentButton> *@
@*     </div> *@
@* *@
@*     <div class="pdm-data-panel"> *@
@*         @if (_loading) *@
@*         { *@
@*             <div class="pdm-loading-state"> *@
@*                 <FluentProgressRing /> *@
@*                 <span>Loading products…</span> *@
@*             </div> *@
@*         } *@
@*         else if (!_products.Any()) *@
@*         { *@
@*             <div class="pdm-empty-state"> *@
@*                 <div class="pdm-empty-state__icon"> *@
@*                     <FluentIcon Value="@(new Icons.Regular.Size24.Box())" Color="Color.Custom" CustomColor="#64748b" /> *@
@*                 </div> *@
@*                 <p>No products yet.</p> *@
@*                 <p>Click "Add Product" to create your first one.</p> *@
@*             </div> *@
@*         } *@
@*         else *@
@*         { *@
@*             <div class="pdm-data-panel__grid-wrapper"> *@
@*                 <FluentDataGrid Items="@_products.AsQueryable()" Pagination="@_pagination" TGridItem="ProductDto" *@
@*                                 Style="width: 100%;" GridTemplateColumns="1fr 0.6fr 0.5fr 0.4fr 0.5fr"> *@
@*                     <PropertyColumn Property="@(p => p.Name)" Title="Name" Sortable="true" /> *@
@*                     <PropertyColumn Property="@(p => p.Sku)" Title="SKU" Sortable="true" /> *@
@*                     <PropertyColumn Property="@(p => p.CategoryName)" Title="Category" /> *@
@*                     <TemplateColumn Title="Status"> *@
@*                         @if (context.IsActive) *@
@*                         { *@
@*                             <span class="pdm-status-badge pdm-status-badge--active"> *@
@*                                 <span class="pdm-status-dot"></span> Active *@
@*                             </span> *@
@*                         } *@
@*                         else *@
@*                         { *@
@*                             <span class="pdm-status-badge pdm-status-badge--inactive"> *@
@*                                 <span class="pdm-status-dot"></span> Inactive *@
@*                             </span> *@
@*                         } *@
@*                     </TemplateColumn> *@
@*                     <TemplateColumn Title=""> *@
@*                         <FluentStack Orientation="Orientation.Horizontal" Style="gap: 2px;"> *@
@*                             <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())" Title="Edit" OnClick="@(() => OpenEditDialog(context))" /> *@
@*                             <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" Title="Delete" OnClick="@(() => ConfirmDelete(context))" /> *@
@*                         </FluentStack> *@
@*                     </TemplateColumn> *@
@*                 </FluentDataGrid> *@
@*             </div> *@
@*             <div class="pdm-data-panel__footer"> *@
@*                 <FluentPaginator State="@_pagination" /> *@
@*             </div> *@
@*         } *@
@*     </div> *@
@* </div> *@
@* *@
@* <FluentDialog @bind-Hidden="@_dialogHidden" Modal="true" TrapFocus="true" PreventScroll="true"> *@
@*     <FluentDialogHeader> *@
@*         <div class="pdm-dialog-header"> *@
@*             <FluentIcon Value="@(_editingProduct is not null ? new Icons.Regular.Size20.Edit() : (Icon)new Icons.Regular.Size20.Add())" *@
@*                         Color="Color.Custom" CustomColor="#22d3ee" /> *@
@*             <h3>@(_editingProduct is not null ? "Edit Product" : "New Product")</h3> *@
@*         </div> *@
@*         <div class="pdm-dialog-subtitle"> *@
@*             @(_editingProduct is not null ? "Update product information" : "Fill in the details for the new product") *@
@*         </div> *@
@*     </FluentDialogHeader> *@
@*     <FluentDialogBody> *@
@*         <FluentStack Orientation="Orientation.Vertical" Class="pdm-dialog-form"> *@
@*             <FluentTextField @bind-Value="_formName" Label="Name" Required="true" Style="width: 100%;" Placeholder="e.g. Wireless Headphones" /> *@
@*             <FluentSelect TOption="CategoryFlatDto" *@
@*                           Items="@_allCategories" *@
@*                           Label="Category" *@
@*                           Required="true" *@
@*                           OptionValue="@(c => c.Id.ToString())" *@
@*                           OptionText="@(c => new string('\u2003', c.Depth) + c.Name)" *@
@*                           @bind-SelectedOption="_selectedCategory" *@
@*                           Style="width: 100%;" *@
@*                           Placeholder="Select a category..." /> *@
@*             <FluentTextArea @bind-Value="_formDescription" Label="Description" Rows="3" Style="width: 100%;" Placeholder="Product description..." /> *@
@*             @if (_editingProduct is not null) *@
@*             { *@
@*                 <FluentCheckbox @bind-Value="_formIsActive" Label="Active" /> *@
@*             } *@
@* *@
@*             @if (_categoryDescriptions.Any()) *@
@*             { *@
@*                 <h4 style="margin: 8px 0 0; font-size: 0.9rem;">Descriptions</h4> *@
@*                 @foreach (var desc in _categoryDescriptions) *@
@*                 { *@
@*                     <FluentSelect TOption="DescriptionValueDto" *@
@*                                   Items="@desc.Values" *@
@*                                   Label="@desc.DescriptionTypeName" *@
@*                                   OptionValue="@(v => v.Id.ToString())" *@
@*                                   OptionText="@(v => v.Value)" *@
@*                                   SelectedOption="@(_selectedDescValues.GetValueOrDefault(desc.DescriptionTypeId))" *@
@*                                   SelectedOptionChanged="@(v => OnDescriptionValueChanged(desc.DescriptionTypeId, v))" *@
@*                                   Style="width: 100%;" *@
@*                                   Placeholder="Select a value..." /> *@
@*                 } *@
@*             } *@
@*         </FluentStack> *@
@*     </FluentDialogBody> *@
@*     <FluentDialogFooter> *@
@*         <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _dialogHidden = true)">Cancel</FluentButton> *@
@*         <FluentButton Appearance="Appearance.Accent" OnClick="HandleSave" Loading="_saving" *@
@*                       IconStart="@(new Icons.Regular.Size16.Checkmark())"> *@
@*             @(_editingProduct is not null ? "Update" : "Create") *@
@*         </FluentButton> *@
@*     </FluentDialogFooter> *@
@* </FluentDialog> *@
@* *@
@* $1$ Confirm Delete Dialog #1# *@
@* <FluentDialog @bind-Hidden="@_confirmDeleteHidden" Modal="true" TrapFocus="true" PreventScroll="true"> *@
@*     <FluentDialogHeader> *@
@*         <div class="pdm-dialog-header"> *@
@*             <FluentIcon Value="@(new Icons.Regular.Size20.Warning())" Color="Color.Custom" CustomColor="#ef4444" /> *@
@*             <h3>Confirm Deletion</h3> *@
@*         </div> *@
@*     </FluentDialogHeader> *@
@*     <FluentDialogBody> *@
@*         <p>Are you sure you want to delete the product <strong>@_productToDelete?.Name</strong>?</p> *@
@*         <p style="font-size: 0.85rem; color: var(--pdm-text-muted);">This action cannot be undone.</p> *@
@*     </FluentDialogBody> *@
@*     <FluentDialogFooter> *@
@*         <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _confirmDeleteHidden = true)">Cancel</FluentButton> *@
@*         <FluentButton Appearance="Appearance.Accent" Style="--accent-fill-rest: #ef4444; --accent-fill-hover: #dc2626;" *@
@*                       OnClick="HandleDelete" Loading="_deleting" *@
@*                       IconStart="@(new Icons.Regular.Size16.Delete())"> *@
@*             Delete *@
@*         </FluentButton> *@
@*     </FluentDialogFooter> *@
@* </FluentDialog> *@
@* *@
@* @code { *@
@*     private List<ProductDto> _products = []; *@
@*     private PaginationState _pagination = new() { ItemsPerPage = 20 }; *@
@*     private bool _loading = true; *@
@*     private bool _dialogHidden = true; *@
@*     private bool _saving; *@
@*     private string _formName = string.Empty; *@
@*     private string? _formDescription; *@
@*     private bool _formIsActive = true; *@
@*     private ProductDto? _editingProduct; *@
@* *@
@*     // Categories & descriptions for the form *@
@*     private List<CategoryFlatDto> _allCategories = []; *@
@*     private CategoryFlatDto? _selectedCategory; *@
@*     private List<CategoryDescriptionRuleDto> _categoryDescriptions = []; *@
@*     private Dictionary<Guid, DescriptionValueDto?> _selectedDescValues = new(); *@
@* *@
@*     // Confirm delete *@
@*     private bool _confirmDeleteHidden = true; *@
@*     private bool _deleting; *@
@*     private ProductDto? _productToDelete; *@
@* *@
@*     protected override async Task OnInitializedAsync() *@
@*     { *@
@*         await LoadProducts(); *@
@*         await LoadCategories(); *@
@*     } *@
@* *@
@*     private async Task LoadProducts() *@
@*     { *@
@*         _loading = true; *@
@*         var response = await ProductsClient.GetResponse<GetProductsResult>(new GetProducts()); *@
@*         _products = response.Message.Products; *@
@*         _loading = false; *@
@*     } *@
@* *@
@*     private async Task LoadCategories() *@
@*     { *@
@*         var response = await CategoriesClient.GetResponse<GetAllCategoriesFlatResult>(new SearchCategory()); *@
@*         _allCategories = response.Message.Categories; *@
@*     } *@
@* *@
@*     private void OpenCreateDialog() *@
@*     { *@
@*         _editingProduct = null; _formName = string.Empty; *@
@*         _formDescription = null; _formIsActive = true; *@
@*         _selectedCategory = null; *@
@*         _categoryDescriptions = []; *@
@*         _selectedDescValues = new(); *@
@*         _dialogHidden = false; *@
@*     } *@
@* *@
@*     private async Task OpenEditDialog(ProductDto product) *@
@*     { *@
@*         _editingProduct = product; _formName = product.Name; *@
@*         _formDescription = product.Description; *@
@*         _formIsActive = product.IsActive; *@
@*         _selectedCategory = _allCategories.FirstOrDefault(c => c.Id == product.CategoryId); *@
@*         _dialogHidden = false; *@
@* *@
@*         // Load descriptions for the product's category *@
@*         if (_selectedCategory is not null) *@
@*             await LoadCategoryDescriptions(product.CategoryId, product.Descriptions); *@
@*     } *@
@* *@
@*     private async Task LoadCategoryDescriptions(Guid categoryId, List<ProductDescriptionDto>? existingDescriptions = null) *@
@*     { *@
@*         var response = await CategoryDescriptionsClient.GetResponse<GetCategoryDescriptionsResult>( *@
@*             new GetCategoryDescriptions(categoryId)); *@
@*         _categoryDescriptions = response.Message.Descriptions; *@
@* *@
@*         _selectedDescValues = new(); *@
@*         if (existingDescriptions is not null) *@
@*         { *@
@*             foreach (var desc in existingDescriptions) *@
@*             { *@
@*                 var rule = _categoryDescriptions.FirstOrDefault(r => r.DescriptionTypeId == desc.TypeId); *@
@*                 var value = rule?.Values.FirstOrDefault(v => v.Id == desc.ValueId); *@
@*                 if (value is not null) *@
@*                     _selectedDescValues[desc.TypeId] = value; *@
@*             } *@
@*         } *@
@*     } *@
@* *@
@*     private async Task OnSelectedCategoryChanged() *@
@*     { *@
@*         if (_selectedCategory is not null) *@
@*             await LoadCategoryDescriptions(_selectedCategory.Id); *@
@*         else *@
@*         { *@
@*             _categoryDescriptions = []; *@
@*             _selectedDescValues = new(); *@
@*         } *@
@*         StateHasChanged(); *@
@*     } *@
@* *@
@*     private void OnDescriptionValueChanged(Guid descriptionTypeId, DescriptionValueDto? value) *@
@*     { *@
@*         _selectedDescValues[descriptionTypeId] = value; *@
@*     } *@
@* *@
@*     private async Task HandleSave() *@
@*     { *@
@*         if (string.IsNullOrWhiteSpace(_formName) || _selectedCategory is null) return; *@
@*         _saving = true; *@
@* *@
@*         if (_editingProduct is not null) *@
@*         { *@
@*             if (_formName != _editingProduct.Name || _formDescription != _editingProduct.Description) *@
@*             { *@
@*                 var r = await UpdateDetailsClient.GetResponse<UpdateProductDetailsResult>( *@
@*                     new UpdateProductDetails(_editingProduct.Id, _formName, _formDescription)); *@
@*                 if (!r.Message.Success) *@
@*                 { ToastService.ShowError(r.Message.ErrorMessage ?? "Failed to update product details."); _saving = false; return; } *@
@*             } *@
@* *@
@*             if (_selectedCategory.Id != _editingProduct.CategoryId) *@
@*             { *@
@*                 var r = await ChangeCategoryClient.GetResponse<ChangeProductCategoryResult>( *@
@*                     new ChangeProductCategory(_editingProduct.Id, _selectedCategory.Id)); *@
@*                 if (!r.Message.Success) *@
@*                 { ToastService.ShowError(r.Message.ErrorMessage ?? "Failed to change category."); _saving = false; return; } *@
@*             } *@
@* *@
@*             if (_formIsActive != _editingProduct.IsActive) *@
@*             { *@
@*                 var r = await ChangeStatusClient.GetResponse<ChangeProductStatusResult>( *@
@*                     new ChangeProductStatus(_editingProduct.Id, _formIsActive)); *@
@*                 if (!r.Message.Success) *@
@*                 { ToastService.ShowError(r.Message.ErrorMessage ?? "Failed to change status."); _saving = false; return; } *@
@*             } *@
@* *@
@*             // Save description selections *@
@*             foreach (var kvp in _selectedDescValues.Where(kv => kv.Value is not null)) *@
@*             { *@
@*                 await SetDescriptionClient.GetResponse<SetProductDescriptionResult>( *@
@*                     new SetProductDescription(_editingProduct.Id, kvp.Key, kvp.Value!.Id)); *@
@*             } *@
@* *@
@*             ToastService.ShowSuccess("Product updated successfully."); *@
@*         } *@
@*         else *@
@*         { *@
@*             var response = await CreateProductClient.GetResponse<CreateProductResult>( *@
@*                 new CreateProduct(_formName, _selectedCategory.Id)); *@
@* *@
@*             if (response.Message.Success) *@
@*             { *@
@*                 // Save description selections for the new product *@
@*                 foreach (var kvp in _selectedDescValues.Where(kv => kv.Value is not null)) *@
@*                 { *@
@*                     await SetDescriptionClient.GetResponse<SetProductDescriptionResult>( *@
@*                         new SetProductDescription(response.Message.Id, kvp.Key, kvp.Value!.Id)); *@
@*                 } *@
@*                 ToastService.ShowSuccess("Product created successfully."); *@
@*             } *@
@*             else *@
@*             { *@
@*                 ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to create product."); *@
@*             } *@
@*         } *@
@* *@
@*         _saving = false; _dialogHidden = true; *@
@*         await LoadProducts(); *@
@*     } *@
@* *@
@*     private void ConfirmDelete(ProductDto product) *@
@*     { *@
@*         _productToDelete = product; *@
@*         _confirmDeleteHidden = false; *@
@*     } *@
@* *@
@*     private async Task HandleDelete() *@
@*     { *@
@*         if (_productToDelete is null) return; *@
@*         _deleting = true; *@
@* *@
@*         var response = await DeleteProductClient.GetResponse<DeleteProductResult>(new DeleteProduct(_productToDelete.Id)); *@
@*         if (response.Message.Success) *@
@*         { *@
@*             ToastService.ShowSuccess($"Product '{_productToDelete.Name}' deleted."); *@
@*             await LoadProducts(); *@
@*         } *@
@*         else *@
@*         { *@
@*             ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to delete product."); *@
@*         } *@
@* *@
@*         _deleting = false; *@
@*         _confirmDeleteHidden = true; *@
@*     } *@
@* } *@
