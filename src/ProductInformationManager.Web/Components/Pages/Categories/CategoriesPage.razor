@page "/categories"
@using MassTransit
@using ProductInformationManager.Messages

@inject IRequestClient<GetRootCategories> RootCategoriesClient
@inject IRequestClient<GetChildCategories> ChildCategoriesClient
@inject IRequestClient<CreateCategory> CreateCategoryClient
@inject IRequestClient<UpdateCategory> UpdateCategoryClient
@inject IRequestClient<DeleteCategory> DeleteCategoryClient
@inject IRequestClient<GetDescriptionTypes> DescriptionTypesClient
@inject IRequestClient<AddCategoryDescriptionRule> AddRuleClient
@inject IRequestClient<RemoveCategoryDescriptionRule> RemoveRuleClient
@inject IRequestClient<GetCategoryDescriptions> CategoryDescriptionsClient
@inject IToastService ToastService

<PageTitle>Categories — Product Data Manager</PageTitle>

<div class="pdm-animate-in">
    <div class="pdm-page-header">
        <div>
            <h1>
                <span class="pdm-page-header-icon">
                    <FluentIcon Value="@(new Icons.Regular.Size20.FolderMultiple())" Color="Color.Custom" CustomColor="#818cf8" />
                </span>
                Categories
            </h1>
            <div style="font-size: 0.85rem; color: var(--pdm-text-muted); margin-top: 2px;">Organize your product catalog into hierarchical categories</div>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="@(() => OpenCreateDialog(null))">
            Add Root Category
        </FluentButton>
    </div>

    @if (_loading)
    {
        <div class="pdm-loading-state">
            <FluentProgressRing />
            <span>Loading categories…</span>
        </div>
    }
    else if (!_rootCategories.Any())
    {
        <div class="pdm-empty-state">
            <div class="pdm-empty-state__icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.FolderMultiple())" Color="Color.Custom" CustomColor="#64748b" />
            </div>
            <p>No categories yet.</p>
            <p>Click "Add Root Category" to create the first one.</p>
        </div>
    }
    else
    {
        <div class="pdm-data-panel pdm-data-panel--padded">
            <FluentTreeView>
                @foreach (var category in _rootCategories)
                {
                    <CategoryTreeItem Category="category"
                                      OnExpand="LoadChildren"
                                      OnEdit="OpenEditDialog"
                                      OnDelete="ConfirmDelete"
                                      OnAddChild="OpenCreateDialog"
                                      OnManageDescriptions="OpenDescriptionRulesDialog" />
                }
            </FluentTreeView>
        </div>
    }
</div>

<FluentDialog @bind-Hidden="@_dialogHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(_editingCategory is not null ? new Icons.Regular.Size20.Edit() : (Icon)new Icons.Regular.Size20.Add())"
                        Color="Color.Custom" CustomColor="#818cf8" />
            <h3>@(_editingCategory is not null ? "Edit Category" : "New Category")</h3>
        </div>
        <div class="pdm-dialog-subtitle">
            @if (_editingCategory is not null)
            { <span>Update the category name and description</span> }
            else if (_parentIdForCreate.HasValue)
            { <span>Create a new child category</span> }
            else
            { <span>Create a new root-level category</span> }
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Class="pdm-dialog-form">
            <FluentTextField @bind-Value="_formName" Label="Name" Required="true" Style="width: 100%;" Placeholder="e.g. Electronics, Clothing..." />
            <FluentTextArea @bind-Value="_formDescription" Label="Description" Rows="3" Style="width: 100%;" Placeholder="Optional description for this category..." />
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _dialogHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="HandleSave" Loading="_saving"
                      IconStart="@(new Icons.Regular.Size16.Checkmark())">
            @(_editingCategory is not null ? "Update" : "Create")
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Confirm Delete Dialog *@
<FluentDialog @bind-Hidden="@_confirmDeleteHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(new Icons.Regular.Size20.Warning())" Color="Color.Custom" CustomColor="#ef4444" />
            <h3>Confirm Deletion</h3>
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <p>Are you sure you want to delete the category <strong>@_categoryToDelete?.Name</strong>?</p>
        <p style="font-size: 0.85rem; color: var(--pdm-text-muted);">This action cannot be undone.</p>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _confirmDeleteHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" Style="--accent-fill-rest: #ef4444; --accent-fill-hover: #dc2626;"
                      OnClick="HandleDelete" Loading="_deleting"
                      IconStart="@(new Icons.Regular.Size16.Delete())">
            Delete
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Description Rules Dialog *@
<FluentDialog @bind-Hidden="@_descRulesHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(new Icons.Regular.Size20.TextDescription())" Color="Color.Custom" CustomColor="#10b981" />
            <h3>Description Rules — @_descRulesCategoryName</h3>
        </div>
        <div class="pdm-dialog-subtitle">Manage which description types are associated with this category</div>
    </FluentDialogHeader>
    <FluentDialogBody>
        @if (_descRulesLoading)
        {
            <div class="pdm-loading-state" style="padding: 24px;">
                <FluentProgressRing />
                <span>Loading descriptions…</span>
            </div>
        }
        else
        {
            @if (_effectiveDescriptions.Any())
            {
                <FluentDataGrid Items="@_effectiveDescriptions.AsQueryable()" TGridItem="CategoryDescriptionRuleDto"
                                Style="width: 100%; margin-bottom: 16px;" GridTemplateColumns="1fr 0.5fr 0.5fr auto">
                    <PropertyColumn Property="@(d => d.DescriptionTypeName)" Title="Description Type" />
                    <TemplateColumn Title="Mandatory">
                        @if (context.IsMandatory)
                        { <FluentBadge Appearance="Appearance.Accent">Yes</FluentBadge> }
                        else
                        { <FluentBadge>No</FluentBadge> }
                    </TemplateColumn>
                    <TemplateColumn Title="Source">
                        @if (context.IsInherited)
                        { <FluentBadge Appearance="Appearance.Neutral" Style="font-size: 0.75rem;">Inherited from @context.SourceCategoryName</FluentBadge> }
                        else
                        { <FluentBadge Appearance="Appearance.Accent" Style="font-size: 0.75rem;">Own</FluentBadge> }
                    </TemplateColumn>
                    <TemplateColumn Title="">
                        @if (!context.IsInherited)
                        {
                            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())"
                                          Title="Remove" OnClick="@(() => HandleRemoveRule(context.DescriptionTypeId))" />
                        }
                    </TemplateColumn>
                </FluentDataGrid>
            }
            else
            {
                <div class="pdm-no-items-text" style="margin-bottom: 16px;">No description rules defined for this category.</div>
            }

            <div class="pdm-inline-form">
                <FluentSelect TOption="DescriptionTypeDto"
                              Items="@_availableDescriptionTypes"
                              OptionValue="@(dt => dt.Id.ToString())"
                              OptionText="@(dt => dt.Name)"
                              @bind-SelectedOption="_selectedDescType"
                              Style="flex: 1;"
                              Placeholder="Select a description type..." />
                <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.Add())"
                              OnClick="HandleAddRule" Disabled="@(_selectedDescType is null)">
                    Add
                </FluentButton>
            </div>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _descRulesHidden = true)">Close</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<CategoryTreeNode> _rootCategories = [];
    private bool _loading = true;
    private bool _dialogHidden = true;
    private bool _saving;
    private string _formName = string.Empty;
    private string? _formDescription;
    private Guid? _parentIdForCreate;
    private CategoryDto? _editingCategory;

    // Confirm delete
    private bool _confirmDeleteHidden = true;
    private bool _deleting;
    private CategoryDto? _categoryToDelete;

    // Description rules
    private bool _descRulesHidden = true;
    private bool _descRulesLoading;
    private Guid _descRulesCategoryId;
    private string _descRulesCategoryName = string.Empty;
    private List<CategoryDescriptionRuleDto> _effectiveDescriptions = [];
    private List<DescriptionTypeDto> _availableDescriptionTypes = [];
    private DescriptionTypeDto? _selectedDescType;

    protected override async Task OnInitializedAsync() => await LoadRootCategories();

    private async Task LoadRootCategories()
    {
        _loading = true;
        var response = await RootCategoriesClient.GetResponse<GetRootCategoriesResult>(new GetRootCategories());
        _rootCategories = response.Message.Categories.Select(c => new CategoryTreeNode(c)).ToList();
        _loading = false;
    }

    private async Task LoadChildren(CategoryTreeNode node)
    {
        if (node.ChildrenLoaded) return;
        node.IsLoading = true;
        StateHasChanged();
        var response = await ChildCategoriesClient.GetResponse<GetChildCategoriesResult>(new GetChildCategories(node.Category.Id));
        node.Children = response.Message.Children.Select(c => new CategoryTreeNode(c)).ToList();
        node.ChildrenLoaded = true;
        node.IsLoading = false;
        StateHasChanged();
    }

    private void OpenCreateDialog(Guid? parentId)
    {
        _parentIdForCreate = parentId; _editingCategory = null;
        _formName = string.Empty; _formDescription = null;
        _dialogHidden = false;
    }

    private void OpenEditDialog(CategoryDto category)
    {
        _editingCategory = category; _parentIdForCreate = null;
        _formName = category.Name; _formDescription = category.Description;
        _dialogHidden = false;
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(_formName)) return;
        _saving = true;

        if (_editingCategory is not null)
        {
            var response = await UpdateCategoryClient.GetResponse<UpdateCategoryResult>(
                new UpdateCategory(_editingCategory.Id, _formName, _formDescription));
            if (response.Message.Success)
                ToastService.ShowSuccess("Category updated successfully.");
            else
                ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to update category.");
        }
        else
        {
            var response = await CreateCategoryClient.GetResponse<CreateCategoryResult>(
                new CreateCategory(_formName, _formDescription, _parentIdForCreate));
            if (response.Message.Success)
                ToastService.ShowSuccess("Category created successfully.");
            else
                ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to create category.");
        }

        _saving = false; _dialogHidden = true;
        await LoadRootCategories();
    }

    private void ConfirmDelete(CategoryDto category)
    {
        _categoryToDelete = category;
        _confirmDeleteHidden = false;
    }

    private async Task HandleDelete()
    {
        if (_categoryToDelete is null) return;
        _deleting = true;

        var response = await DeleteCategoryClient.GetResponse<DeleteCategoryResult>(new DeleteCategory(_categoryToDelete.Id));
        if (response.Message.Success)
        {
            ToastService.ShowSuccess($"Category '{_categoryToDelete.Name}' deleted.");
            await LoadRootCategories();
        }
        else
        {
            ToastService.ShowError(response.Message.ErrorMessage ?? "Cannot delete category.");
        }

        _deleting = false;
        _confirmDeleteHidden = true;
    }

    private async Task OpenDescriptionRulesDialog(CategoryDto category)
    {
        _descRulesCategoryId = category.Id;
        _descRulesCategoryName = category.Name;
        _descRulesHidden = false;
        _descRulesLoading = true;
        StateHasChanged();

        await LoadDescriptionRules();
        _descRulesLoading = false;
    }

    private async Task LoadDescriptionRules()
    {
        var descriptionsTask = CategoryDescriptionsClient.GetResponse<GetCategoryDescriptionsResult>(
            new GetCategoryDescriptions(_descRulesCategoryId));
        var typesTask = DescriptionTypesClient.GetResponse<GetDescriptionTypesResult>(new GetDescriptionTypes());

        await Task.WhenAll(descriptionsTask, typesTask);

        _effectiveDescriptions = (await descriptionsTask).Message.Descriptions;
        var allTypes = (await typesTask).Message.DescriptionTypes;

        var usedTypeIds = _effectiveDescriptions
            .Where(d => !d.IsInherited)
            .Select(d => d.DescriptionTypeId)
            .ToHashSet();
        _availableDescriptionTypes = allTypes.Where(t => !usedTypeIds.Contains(t.Id)).ToList();
        _selectedDescType = null;
    }

    private async Task HandleAddRule()
    {
        if (_selectedDescType is null) return;
        var response = await AddRuleClient.GetResponse<AddCategoryDescriptionRuleResult>(
            new AddCategoryDescriptionRule(_descRulesCategoryId, _selectedDescType.Id, false));

        if (response.Message.Success)
        {
            ToastService.ShowSuccess($"Description '{_selectedDescType.Name}' associated.");
            await LoadDescriptionRules();
            StateHasChanged();
        }
        else
        {
            ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to add description rule.");
        }
    }

    private async Task HandleRemoveRule(Guid descriptionTypeId)
    {
        var response = await RemoveRuleClient.GetResponse<RemoveCategoryDescriptionRuleResult>(
            new RemoveCategoryDescriptionRule(_descRulesCategoryId, descriptionTypeId));

        if (response.Message.Success)
        {
            ToastService.ShowSuccess("Description rule removed.");
            await LoadDescriptionRules();
            StateHasChanged();
        }
        else
        {
            ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to remove description rule.");
        }
    }

    public class CategoryTreeNode(CategoryDto category)
    {
        public CategoryDto Category { get; set; } = category;
        public List<CategoryTreeNode> Children { get; set; } = [];
        public bool ChildrenLoaded { get; set; }
        public bool IsLoading { get; set; }
        public bool IsExpanded { get; set; }
    }
}
