@page "/categories"
@using MassTransit
@using ProductDataManager.Infrastructure.Messages.Categories

@inject IRequestClient<GetRootCategories> RootCategoriesClient
@inject IRequestClient<GetChildCategories> ChildCategoriesClient
@inject IRequestClient<CreateCategory> CreateCategoryClient
@inject IRequestClient<UpdateCategory> UpdateCategoryClient
@inject IRequestClient<DeleteCategory> DeleteCategoryClient
@inject IToastService ToastService

<PageTitle>Categories — Product Data Manager</PageTitle>

<div class="pdm-animate-in">
    <div class="pdm-page-header">
        <div>
            <h1>
                <span class="pdm-page-header-icon">
                    <FluentIcon Value="@(new Icons.Regular.Size20.FolderMultiple())" Color="Color.Custom" CustomColor="#818cf8" />
                </span>
                Categories
            </h1>
            <div style="font-size: 0.85rem; color: var(--pdm-text-muted); margin-top: 2px;">Organize your product catalog into hierarchical categories</div>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="@(() => OpenCreateDialog(null))">
            Add Root Category
        </FluentButton>
    </div>

    @if (_loading)
    {
        <div style="display: flex; flex-direction: column; align-items: center; padding: 48px; gap: 16px; color: var(--pdm-text-muted);">
            <FluentProgressRing />
            <span>Loading categories…</span>
        </div>
    }
    else if (!_rootCategories.Any())
    {
        <div style="text-align: center; padding: 48px; color: var(--pdm-text-muted);">
            <div style="width: 56px; height: 56px; margin: 0 auto 16px; background: var(--pdm-bg-subtle); border-radius: var(--pdm-radius-lg); display: flex; align-items: center; justify-content: center; opacity: 0.5;">
                <FluentIcon Value="@(new Icons.Regular.Size24.FolderMultiple())" Color="Color.Custom" CustomColor="#64748b" />
            </div>
            <p style="margin: 0;">No categories yet.</p>
            <p style="font-size: 0.8rem; margin-top: 4px;">Click "Add Root Category" to create the first one.</p>
        </div>
    }
    else
    {
        <div style="background: var(--pdm-bg-card); border: 1px solid var(--pdm-border); border-radius: var(--pdm-radius-lg); padding: 16px;">
            <FluentTreeView>
                @foreach (var category in _rootCategories)
                {
                    <CategoryTreeItem Category="category"
                                      OnExpand="LoadChildren"
                                      OnEdit="OpenEditDialog"
                                      OnDelete="HandleDelete"
                                      OnAddChild="OpenCreateDialog" />
                }
            </FluentTreeView>
        </div>
    }
</div>

<FluentDialog @bind-Hidden="@_dialogHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
            <FluentIcon Value="@(_editingCategory is not null ? new Icons.Regular.Size20.Edit() : (Icon)new Icons.Regular.Size20.Add())"
                        Color="Color.Custom" CustomColor="#818cf8" />
            <h3 style="margin: 0;">@(_editingCategory is not null ? "Edit Category" : "New Category")</h3>
        </div>
        <div style="font-size: 0.825rem; color: var(--pdm-text-muted); margin-bottom: 16px;">
            @if (_editingCategory is not null)
            { <span>Update the category name and description</span> }
            else if (_parentIdForCreate.HasValue)
            { <span>Create a new child category</span> }
            else
            { <span>Create a new root-level category</span> }
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px; min-width: 420px;">
            <FluentTextField @bind-Value="_formName" Label="Name" Required="true" Style="width: 100%;" Placeholder="e.g. Electronics, Clothing..." />
            <FluentTextArea @bind-Value="_formDescription" Label="Description" Rows="3" Style="width: 100%;" Placeholder="Optional description for this category..." />
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _dialogHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="HandleSave" Loading="_saving"
                      IconStart="@(new Icons.Regular.Size16.Checkmark())">
            @(_editingCategory is not null ? "Update" : "Create")
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<CategoryTreeNode> _rootCategories = [];
    private bool _loading = true;
    private bool _dialogHidden = true;
    private bool _saving;
    private string _formName = string.Empty;
    private string? _formDescription;
    private Guid? _parentIdForCreate;
    private CategoryDto? _editingCategory;

    protected override async Task OnInitializedAsync() => await LoadRootCategories();

    private async Task LoadRootCategories()
    {
        _loading = true;
        var response = await RootCategoriesClient.GetResponse<GetRootCategoriesResult>(new GetRootCategories());
        _rootCategories = response.Message.Categories.Select(c => new CategoryTreeNode(c)).ToList();
        _loading = false;
    }

    private async Task LoadChildren(CategoryTreeNode node)
    {
        if (node.ChildrenLoaded) return;
        node.IsLoading = true;
        StateHasChanged();
        var response = await ChildCategoriesClient.GetResponse<GetChildCategoriesResult>(new GetChildCategories(node.Category.Id));
        node.Children = response.Message.Children.Select(c => new CategoryTreeNode(c)).ToList();
        node.ChildrenLoaded = true;
        node.IsLoading = false;
        StateHasChanged();
    }

    private void OpenCreateDialog(Guid? parentId)
    {
        _parentIdForCreate = parentId; _editingCategory = null;
        _formName = string.Empty; _formDescription = null;
        _dialogHidden = false;
    }

    private void OpenEditDialog(CategoryDto category)
    {
        _editingCategory = category; _parentIdForCreate = null;
        _formName = category.Name; _formDescription = category.Description;
        _dialogHidden = false;
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(_formName)) return;
        _saving = true;

        if (_editingCategory is not null)
        {
            var response = await UpdateCategoryClient.GetResponse<UpdateCategoryResult>(
                new UpdateCategory(_editingCategory.Id, _formName, _formDescription));
            ToastService.ShowSuccess(response.Message.Success ? "Category updated successfully." : "Failed to update category.");
        }
        else
        {
            var response = await CreateCategoryClient.GetResponse<CreateCategoryResult>(
                new CreateCategory(_formName, _formDescription, _parentIdForCreate));
            ToastService.ShowSuccess(response.Message.Id != Guid.Empty ? "Category created successfully." : "Failed to create category.");
        }

        _saving = false; _dialogHidden = true;
        await LoadRootCategories();
    }

    private async Task HandleDelete(CategoryDto category)
    {
        var response = await DeleteCategoryClient.GetResponse<DeleteCategoryResult>(new DeleteCategory(category.Id));
        if (response.Message.Success)
        { ToastService.ShowSuccess($"Category '{category.Name}' deleted."); await LoadRootCategories(); }
        else
        { ToastService.ShowError("Cannot delete category (it may have children or products)."); }
    }

    public class CategoryTreeNode(CategoryDto category)
    {
        public CategoryDto Category { get; set; } = category;
        public List<CategoryTreeNode> Children { get; set; } = [];
        public bool ChildrenLoaded { get; set; }
        public bool IsLoading { get; set; }
        public bool IsExpanded { get; set; }
    }
}
