<FluentTreeItem Text="@Category.Category.Name" Expanded="@Category.IsExpanded" ExpandedChanged="HandleExpandedChanged">

    <FluentStack HorizontalAlignment="HorizontalAlignment.End" Orientation="Orientation.Horizontal" Gap="2" Class="pdm-tree-actions">
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Add())" Title="Aggiungi sottocategoria" OnClick="@(() => OnAddChild.InvokeAsync(Category.Category.Id))" OnClick:stopPropagation="true" />
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())" Title="Modifica" OnClick="@(() => OnEdit.InvokeAsync(Category.Category))" OnClick:stopPropagation="true" />
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" Title="Elimina" OnClick="@(() => OnDelete.InvokeAsync(Category.Category))" OnClick:stopPropagation="true" />
    </FluentStack>

    @if (Category.IsLoading)
    {
        <FluentTreeItem>
            <FluentProgressRing Class="pdm-tree-loading-ring" />
            Caricamento...
        </FluentTreeItem>
    }
    else
        switch (Category)
        {
            case { HasLoadedChildren: true, Children.Count: > 0 }:
            {
                foreach (var child in Category.Children)
                {
                    <CategoryTreeItem Category="child" 
                                      OnExpand="OnExpand" 
                                      OnEdit="OnEdit" 
                                      OnDelete="OnDelete" 
                                      OnAddChild="OnAddChild" />
                }

                break;
            }
            case { HasLoadedChildren: false, Category.HasChildren: true }:
                /* HACK: Nodo "fantasma" invisibile per mostrare la freccia di espansione (necessario per FluentUI). */
                <FluentTreeItem Class="pdm-tree-ghost-node" />
                break;
        }
</FluentTreeItem>

@code {
    [Parameter, EditorRequired] public required CategoryTreeNode Category { get; set; }
    
    [Parameter] public EventCallback<CategoryTreeNode> OnExpand { get; set; }
    [Parameter] public EventCallback<CategoryDto> OnEdit { get; set; }
    [Parameter] public EventCallback<CategoryDto> OnDelete { get; set; }
    [Parameter] public EventCallback<Guid> OnAddChild { get; set; }

    private async Task HandleExpandedChanged(bool expanded)
    {
        Category.IsExpanded = expanded;
        
        if (expanded && Category is { HasLoadedChildren: false, Category.HasChildren: true, IsLoading: false })
        {
            await OnExpand.InvokeAsync(Category);
        }
    }
}