@page "/attribute-types"
@using MassTransit

@inject IRequestClient<GetAttributeTypes> AttributeTypesClient
@inject IRequestClient<CreateAttributeType> CreateTypeClient
@inject IRequestClient<UpdateAttributeType> UpdateTypeClient
@inject IRequestClient<DeleteAttributeType> DeleteTypeClient
@inject IRequestClient<CreateAttribute> CreateAttributeClient
@inject IRequestClient<DeleteAttribute> DeleteAttributeClient
@inject IToastService ToastService

<PageTitle>Attribute Types — Product Data Manager</PageTitle>

<div class="pdm-animate-in">
    <div class="pdm-page-header">
        <div>
            <h1>
                <span class="pdm-page-header-icon" style="background: rgba(245, 158, 11, 0.12);">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Tag())" Color="Color.Custom" CustomColor="#f59e0b"/>
                </span>
                Attribute Types
            </h1>
            <div style="font-size: 0.85rem; color: var(--pdm-text-muted); margin-top: 2px;">Define custom attributes
                with key-value pairs for product specifications
            </div>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="OpenCreateDialog">
            Add Attribute Type
        </FluentButton>
    </div>

    @if (_loading) {
        <div class="pdm-loading-state">
            <FluentProgressRing/>
            <span>Loading attribute types…</span>
        </div>
    } else if (!_attributeTypes.Any()) {
        <div class="pdm-empty-state">
            <div class="pdm-empty-state__icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.Tag())" Color="Color.Custom" CustomColor="#64748b"/>
            </div>
            <p>No attribute types yet.</p>
            <p>Click "Add Attribute Type" to start defining product attributes.</p>
        </div>
    } else {
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
            @foreach (var at in _attributeTypes) {
                <div class="pdm-section-card">
                    <div class="pdm-section-card__header">
                        <div class="pdm-section-card__body">
                            <h3 class="pdm-section-card__title">@at.Name</h3>
                            @if (!string.IsNullOrEmpty(at.Description)) {
                                <div class="pdm-section-card__description">@at.Description</div>
                            }
                        </div>
                        <div class="pdm-section-card__actions">
                            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())"
                                          Title="Edit" OnClick="@(() => OpenEditDialog(at))"/>
                            <FluentButton Appearance="Appearance.Stealth"
                                          IconStart="@(new Icons.Regular.Size16.Delete())" Title="Delete"
                                          OnClick="@(() => ConfirmDeleteType(at))"/>
                        </div>
                    </div>

                    <div class="pdm-section-card__content">
                        @if (at.Attributes.Any()) {
                            <FluentDataGrid Items="@at.Attributes.AsQueryable()" TGridItem="AttributeDto"
                                            Style="width: 100%;" GridTemplateColumns="1fr 1fr auto">
                                <PropertyColumn Property="@(a => a.Name)" Title="Name"/>
                                <PropertyColumn Property="@(a => a.Value)" Title="Value"/>
                                <TemplateColumn Title="">
                                    <FluentButton Appearance="Appearance.Stealth"
                                                  IconStart="@(new Icons.Regular.Size16.Delete())" Title="Remove"
                                                  OnClick="@(() => ConfirmDeleteAttribute(context.Id))"/>
                                </TemplateColumn>
                            </FluentDataGrid>
                        } else {
                            <div class="pdm-no-items-text">No attributes defined yet.</div>
                        }

                        <div class="pdm-inline-form">
                            <FluentTextField @bind-Value="_newAttrName" Placeholder="Attribute name" Style="flex: 1;"/>
                            <FluentTextField @bind-Value="_newAttrValue" Placeholder="Value" Style="flex: 1;"/>
                            <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.Add())"
                                          OnClick="@(() => HandleAddAttribute(at.Id))">Add
                            </FluentButton>
                        </div>
                    </div>
                </div>
            }
        </FluentStack>
    }
</div>

<FluentDialog @bind-Hidden="@_dialogHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon
                Value="@(_editing is not null ? new Icons.Regular.Size20.Edit() : (Icon)new Icons.Regular.Size20.Add())"
                Color="Color.Custom" CustomColor="#f59e0b"/>
            <h3>@(_editing is not null ? "Edit Attribute Type" : "New Attribute Type")</h3>
        </div>
        <div class="pdm-dialog-subtitle">
            @(_editing is not null ? "Update the attribute type details" : "Define a new attribute type for products")
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Class="pdm-dialog-form">
            <FluentTextField @bind-Value="_formName" Label="Name" Required="true" Style="width: 100%;"
                             Placeholder="e.g. Color, Size, Material..."/>
            <FluentTextArea @bind-Value="_formDescription" Label="Description" Rows="2" Style="width: 100%;"
                            Placeholder="Optional description..."/>
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _dialogHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="HandleSave" Loading="_saving"
                      IconStart="@(new Icons.Regular.Size16.Checkmark())">
            @(_editing is not null ? "Update" : "Create")
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Confirm Delete Type Dialog *@
<FluentDialog @bind-Hidden="@_confirmDeleteHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(new Icons.Regular.Size20.Warning())" Color="Color.Custom" CustomColor="#ef4444"/>
            <h3>Confirm Deletion</h3>
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <p>Are you sure you want to delete the attribute type <strong>@_typeToDelete?.Name</strong>?</p>
        <p style="font-size: 0.85rem; color: var(--pdm-text-muted);">This will also remove all associated attributes.
            This action cannot be undone.</p>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _confirmDeleteHidden = true)">Cancel
        </FluentButton>
        <FluentButton Appearance="Appearance.Accent" Style="--accent-fill-rest: #ef4444; --accent-fill-hover: #dc2626;"
                      OnClick="HandleDeleteType" Loading="_deleting"
                      IconStart="@(new Icons.Regular.Size16.Delete())">
            Delete
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Confirm Delete Attribute Dialog *@
<FluentDialog @bind-Hidden="@_confirmDeleteAttrHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(new Icons.Regular.Size20.Warning())" Color="Color.Custom" CustomColor="#ef4444"/>
            <h3>Confirm Attribute Deletion</h3>
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <p>Are you sure you want to delete this attribute?</p>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _confirmDeleteAttrHidden = true)">Cancel
        </FluentButton>
        <FluentButton Appearance="Appearance.Accent" Style="--accent-fill-rest: #ef4444; --accent-fill-hover: #dc2626;"
                      OnClick="HandleDeleteAttribute" Loading="_deletingAttr"
                      IconStart="@(new Icons.Regular.Size16.Delete())">
            Delete
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<AttributeTypeDto> _attributeTypes = [];
    private bool _loading = true;
    private bool _dialogHidden = true;
    private bool _saving;
    private string _formName = string.Empty;
    private string? _formDescription;
    private string _newAttrName = string.Empty;
    private string _newAttrValue = string.Empty;
    private AttributeTypeDto? _editing;

    // Confirm delete type
    private bool _confirmDeleteHidden = true;
    private bool _deleting;
    private AttributeTypeDto? _typeToDelete;

    // Confirm delete attribute
    private bool _confirmDeleteAttrHidden = true;
    private bool _deletingAttr;
    private Guid _attrToDeleteId;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData() {
        _loading = true;
        var response = await AttributeTypesClient.GetResponse<GetAttributeTypesResult>(new GetAttributeTypes());
        _attributeTypes = response.Message.AttributeTypes;
        _loading = false;
    }

    private void OpenCreateDialog() {
        _editing = null;
        _formName = string.Empty;
        _formDescription = null;
        _dialogHidden = false;
    }

    private void OpenEditDialog(AttributeTypeDto at) {
        _editing = at;
        _formName = at.Name;
        _formDescription = at.Description;
        _dialogHidden = false;
    }

    private async Task HandleSave() {
        if (string.IsNullOrWhiteSpace(_formName)) return;
        _saving = true;
        if (_editing is not null) {
            var response = await UpdateTypeClient.GetResponse<UpdateAttributeTypeResult>(new UpdateAttributeType(_editing.Id, _formName, _formDescription));
            if (response.Message.Success)
                ToastService.ShowSuccess("Attribute type updated.");
            else
                ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to update attribute type.");
        } else {
            var response = await CreateTypeClient.GetResponse<CreateAttributeTypeResult>(new CreateAttributeType(_formName, _formDescription));
            if (response.Message.Success)
                ToastService.ShowSuccess("Attribute type created.");
            else
                ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to create attribute type.");
        }

        _saving = false;
        _dialogHidden = true;
        await LoadData();
    }

    private void ConfirmDeleteType(AttributeTypeDto at) {
        _typeToDelete = at;
        _confirmDeleteHidden = false;
    }

    private async Task HandleDeleteType() {
        if (_typeToDelete is null) return;
        _deleting = true;
        var response = await DeleteTypeClient.GetResponse<DeleteAttributeTypeResult>(new DeleteAttributeType(_typeToDelete.Id));
        if (response.Message.Success) {
            ToastService.ShowSuccess($"'{_typeToDelete.Name}' deleted.");
            await LoadData();
        } else {
            ToastService.ShowError(response.Message.ErrorMessage ?? "Cannot delete attribute type.");
        }

        _deleting = false;
        _confirmDeleteHidden = true;
    }

    private async Task HandleAddAttribute(Guid typeId) {
        if (string.IsNullOrWhiteSpace(_newAttrName) || string.IsNullOrWhiteSpace(_newAttrValue)) return;
        var response = await CreateAttributeClient.GetResponse<CreateAttributeResult>(new CreateAttribute(_newAttrName, _newAttrValue, typeId));
        if (response.Message.Success)
            ToastService.ShowSuccess("Attribute added.");
        else
            ToastService.ShowError(response.Message.ErrorMessage ?? "Failed to add attribute.");
        _newAttrName = string.Empty;
        _newAttrValue = string.Empty;
        await LoadData();
    }

    private void ConfirmDeleteAttribute(Guid attributeId) {
        _attrToDeleteId = attributeId;
        _confirmDeleteAttrHidden = false;
    }

    private async Task HandleDeleteAttribute() {
        _deletingAttr = true;
        var response = await DeleteAttributeClient.GetResponse<DeleteAttributeResult>(new DeleteAttribute(_attrToDeleteId));
        if (response.Message.Success) {
            ToastService.ShowSuccess("Attribute deleted.");
            await LoadData();
        } else {
            ToastService.ShowError(response.Message.ErrorMessage ?? "Cannot delete attribute.");
        }

        _deletingAttr = false;
        _confirmDeleteAttrHidden = true;
    }
}
