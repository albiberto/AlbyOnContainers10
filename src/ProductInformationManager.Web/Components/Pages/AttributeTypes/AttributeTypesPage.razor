@page "/attribute-types"
@using MassTransit

@inject IRequestClient<GetAttributeTypes> AttributeTypesClient
@inject IRequestClient<CreateAttributeType> CreateTypeClient
@inject IRequestClient<UpdateAttributeType> UpdateTypeClient
@inject IRequestClient<DeleteAttributeType> DeleteTypeClient
@inject IRequestClient<CreateAttribute> CreateAttributeClient
@inject IRequestClient<DeleteAttribute> DeleteAttributeClient
@inject IToastService ToastService

<PageTitle>Attribute Types — Product Data Manager</PageTitle>

<div class="pdm-animate-in">
    <div class="pdm-page-header">
        <div>
            <h1>
                <span class="pdm-page-header-icon" style="background: rgba(245, 158, 11, 0.12);">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Tag())" Color="Color.Custom" CustomColor="#f59e0b" />
                </span>
                Attribute Types
            </h1>
            <div style="font-size: 0.85rem; color: var(--pdm-text-muted); margin-top: 2px;">Define custom attributes with key-value pairs for product specifications</div>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="OpenCreateDialog">
            Add Attribute Type
        </FluentButton>
    </div>

    @if (_loading)
    {
        <div class="pdm-loading-state">
            <FluentProgressRing />
            <span>Loading attribute types…</span>
        </div>
    }
    else if (!_attributeTypes.Any())
    {
        <div class="pdm-empty-state">
            <div class="pdm-empty-state__icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.Tag())" Color="Color.Custom" CustomColor="#64748b" />
            </div>
            <p>No attribute types yet.</p>
            <p>Click "Add Attribute Type" to start defining product attributes.</p>
        </div>
    }
    else
    {
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
            @foreach (var at in _attributeTypes)
            {
                <div class="pdm-section-card">
                    <div class="pdm-section-card__header">
                        <div class="pdm-section-card__body">
                            <h3 class="pdm-section-card__title">@at.Name</h3>
                            @if (!string.IsNullOrEmpty(at.Description))
                            {
                                <div class="pdm-section-card__description">@at.Description</div>
                            }
                        </div>
                        <div class="pdm-section-card__actions">
                            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())" Title="Edit" OnClick="@(() => OpenEditDialog(at))" />
                            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" Title="Delete" OnClick="@(() => HandleDeleteType(at))" />
                        </div>
                    </div>

                    <div class="pdm-section-card__content">
                        @if (at.Attributes.Any())
                        {
                            <FluentDataGrid Items="@at.Attributes.AsQueryable()" TGridItem="AttributeDto"
                                            Style="width: 100%;" GridTemplateColumns="1fr 1fr auto">
                                <PropertyColumn Property="@(a => a.Name)" Title="Name" />
                                <PropertyColumn Property="@(a => a.Value)" Title="Value" />
                                <TemplateColumn Title="">
                                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" Title="Remove" OnClick="@(() => HandleDeleteAttribute(context.Id))" />
                                </TemplateColumn>
                            </FluentDataGrid>
                        }
                        else
                        {
                            <div class="pdm-no-items-text">No attributes defined yet.</div>
                        }

                        <div class="pdm-inline-form">
                            <FluentTextField @bind-Value="_newAttrName" Placeholder="Attribute name" Style="flex: 1;" />
                            <FluentTextField @bind-Value="_newAttrValue" Placeholder="Value" Style="flex: 1;" />
                            <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.Add())" OnClick="@(() => HandleAddAttribute(at.Id))">Add</FluentButton>
                        </div>
                    </div>
                </div>
            }
        </FluentStack>
    }
</div>

<FluentDialog @bind-Hidden="@_dialogHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(_editing is not null ? new Icons.Regular.Size20.Edit() : (Icon)new Icons.Regular.Size20.Add())"
                        Color="Color.Custom" CustomColor="#f59e0b" />
            <h3>@(_editing is not null ? "Edit Attribute Type" : "New Attribute Type")</h3>
        </div>
        <div class="pdm-dialog-subtitle">
            @(_editing is not null ? "Update the attribute type details" : "Define a new attribute type for products")
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Class="pdm-dialog-form">
            <FluentTextField @bind-Value="_formName" Label="Name" Required="true" Style="width: 100%;" Placeholder="e.g. Color, Size, Material..." />
            <FluentTextArea @bind-Value="_formDescription" Label="Description" Rows="2" Style="width: 100%;" Placeholder="Optional description..." />
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _dialogHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="HandleSave" Loading="_saving" IconStart="@(new Icons.Regular.Size16.Checkmark())">
            @(_editing is not null ? "Update" : "Create")
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<AttributeTypeDto> _attributeTypes = [];
    private bool _loading = true;
    private bool _dialogHidden = true;
    private bool _saving;
    private string _formName = string.Empty;
    private string? _formDescription;
    private string _newAttrName = string.Empty;
    private string _newAttrValue = string.Empty;
    private AttributeTypeDto? _editing;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        var response = await AttributeTypesClient.GetResponse<GetAttributeTypesResult>(new GetAttributeTypes());
        _attributeTypes = response.Message.AttributeTypes;
        _loading = false;
    }

    private void OpenCreateDialog() { _editing = null; _formName = string.Empty; _formDescription = null; _dialogHidden = false; }

    private void OpenEditDialog(AttributeTypeDto at) { _editing = at; _formName = at.Name; _formDescription = at.Description; _dialogHidden = false; }

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(_formName)) return;
        _saving = true;
        if (_editing is not null)
        {
            await UpdateTypeClient.GetResponse<UpdateAttributeTypeResult>(new UpdateAttributeType(_editing.Id, _formName, _formDescription));
            ToastService.ShowSuccess("Attribute type updated.");
        }
        else
        {
            await CreateTypeClient.GetResponse<CreateAttributeTypeResult>(new CreateAttributeType(_formName, _formDescription));
            ToastService.ShowSuccess("Attribute type created.");
        }
        _saving = false; _dialogHidden = true; await LoadData();
    }

    private async Task HandleDeleteType(AttributeTypeDto at)
    {
        var response = await DeleteTypeClient.GetResponse<DeleteAttributeTypeResult>(new DeleteAttributeType(at.Id));
        if (response.Message.Success) { ToastService.ShowSuccess($"'{at.Name}' deleted."); await LoadData(); }
        else ToastService.ShowError("Failed to delete.");
    }

    private async Task HandleAddAttribute(Guid typeId)
    {
        if (string.IsNullOrWhiteSpace(_newAttrName) || string.IsNullOrWhiteSpace(_newAttrValue)) return;
        await CreateAttributeClient.GetResponse<CreateAttributeResult>(new CreateAttribute(_newAttrName, _newAttrValue, typeId));
        _newAttrName = string.Empty; _newAttrValue = string.Empty; await LoadData();
    }

    private async Task HandleDeleteAttribute(Guid attributeId)
    {
        await DeleteAttributeClient.GetResponse<DeleteAttributeResult>(new DeleteAttribute(attributeId));
        await LoadData();
    }
}
