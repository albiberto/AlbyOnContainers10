{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "MassTransit": "Warning"
    }
  },
  "Observability": {
    "EfCore": {
      "SlowCommandThresholdMs": 250
    }
  },
  "DistributedLock": {
    "RedisChannel": "pim-global-locks",
    "AcquireTimeout": "00:00:02",
    "KeyPrefix": "pim-lock:"
  },

  "Keycloak": {
    "Authority": "http://localhost:8080/realms/productdatamanager",
    "ClientId": "productdatamanager-web",
    "ClientSecret": "secret"
  }
}
