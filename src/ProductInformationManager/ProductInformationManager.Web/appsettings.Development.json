{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "MassTransit": "Warning"
    }
  },

  "Persistence": {
    "EnableSensitiveDataLogging": true,
    "EnableDetailedErrors": true,
    "SlowQueryThresholdMs": 250
  },

  "DistributedLock": {
    "RedisChannel": "pim-global-locks",
    "AcquireTimeout": "00:00:02",
    "KeyPrefix": "pim-lock:"
  }
}
