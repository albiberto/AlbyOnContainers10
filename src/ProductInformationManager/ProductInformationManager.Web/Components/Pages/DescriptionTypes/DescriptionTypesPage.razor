@page "/description-types"
@using MassTransit
@inject IRequestClient<GetDescriptionTypes> DescriptionTypesClient
@inject IRequestClient<DeleteDescriptionType> DeleteClient
@inject IToastService ToastService
@inject NavigationManager NavManager

<PageTitle>Description Types – Product Data Manager</PageTitle>

<div class="pdm-animate-in">
    <div class="pdm-page-header">
        <div>
            <h1>
                <span class="pdm-page-header-icon pdm-page-header-icon--success">
                    <FluentIcon Value="@(new Icons.Regular.Size20.TextDescription())" Color="Color.Custom"
                                CustomColor="var(--pdm-success)"/>
                </span>
                Description Types
            </h1>
            <p class="pdm-page-subtitle">Define structured description schemas with configurable value sets</p>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="OpenCreateDialog">
            Add Description Type
        </FluentButton>
    </div>

    @if (_loading) {
        <div class="pdm-loading-state pdm-state-panel">
            <FluentProgressRing/>
            <span>Loading description types…</span>
        </div>
    } else if (!_descriptionTypes.Any()) {
        <div class="pdm-empty-state pdm-state-panel">
            <div class="pdm-empty-state__icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.TextDescription())" Color="Color.Custom"
                            CustomColor="var(--pdm-text-muted)"/>
            </div>
            <p>No description types yet.</p>
            <p>Click "Add Description Type" to start defining product descriptions.</p>
        </div>
    } else {
        <div class="dt-grid">
            @foreach (var dt in _descriptionTypes) {
                <div class="pdm-section-card dt-card">
                    <div class="dt-card__header">
                        <div class="dt-card__title-row">
                            <h3 class="dt-card__name">@dt.Name</h3>
                            @if (dt.IsGlobal) {
                                <span class="pdm-badge pdm-badge--global">Global</span>
                            } else if (!string.IsNullOrEmpty(dt.CategoryName)) {
                                <span class="pdm-badge pdm-badge--category">@dt.CategoryName</span>
                            }
                        </div>
                        <div class="dt-card__actions">
                            <FluentButton Appearance="Appearance.Stealth"
                                          IconStart="@(new Icons.Regular.Size16.Edit())"
                                          Title="Edit"
                                          OnClick="@(() => EditType(dt.Id))"/>
                            <FluentButton Appearance="Appearance.Stealth"
                                          IconStart="@(new Icons.Regular.Size16.Delete())"
                                          Title="Delete"
                                          OnClick="@(() => ConfirmDelete(dt))"/>
                        </div>
                    </div>

                    <div class="dt-card__divider"></div>

                    <div class="pdm-tags-container">
                        @foreach (var value in dt.Values.Take(10)) {
                            <span class="pdm-tag dt-tag--neutral">@value.Value</span>
                        }
                        @if (dt.Values.Count > 10) {
                            <span class="pdm-no-items-text">+@(dt.Values.Count - 10) additional</span>
                        } else if (dt.Values.Count == 0) {
                            <span class="pdm-no-items-text">No values defined</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<FluentDialog @bind-Hidden="@_confirmDeleteHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader>
        <div class="pdm-dialog-header">
            <FluentIcon Value="@(new Icons.Regular.Size20.Warning())" Color="Color.Custom" CustomColor="var(--pdm-danger)"/>
            <h3>Confirm Deletion</h3>
        </div>
    </FluentDialogHeader>
    <FluentDialogBody>
        <p>Are you sure you want to delete the description type <strong>@_typeToDelete?.Name</strong>?</p>
        <p class="pdm-dialog-hint">This will also remove all associated values. This action cannot be undone.</p>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _confirmDeleteHidden = true)">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent"
                      Class="pdm-btn--danger"
                      OnClick="HandleDelete"
                      Loading="_deleting"
                      IconStart="@(new Icons.Regular.Size16.Delete())">
            Delete
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<DescriptionTypeDto> _descriptionTypes = [];
    private bool _loading = true;
    private bool _confirmDeleteHidden = true;
    private bool _deleting;
    private DescriptionTypeDto? _typeToDelete;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData() {
        _loading = true;
        var response = await DescriptionTypesClient.GetResponse<GetDescriptionTypesResult>(new());
        _descriptionTypes = response.Message.DescriptionTypes;
        _loading = false;
    }

    private void OpenCreateDialog() => NavManager.NavigateTo("/description-types/edit");
    private void EditType(Guid id) => NavManager.NavigateTo($"/description-types/edit?id={id}");

    private void ConfirmDelete(DescriptionTypeDto dt) {
        _typeToDelete = dt;
        _confirmDeleteHidden = false;
    }

    private async Task HandleDelete() {
        if (_typeToDelete is null) return;
        _deleting = true;
        var response = await DeleteClient.GetResponse<DeleteDescriptionTypeResult>(new(_typeToDelete.Id));
        if (response.Message.Success) {
            ToastService.ShowSuccess($"'{_typeToDelete.Name}' deleted.");
            await LoadData();
        } else {
            ToastService.ShowError(response.Message.ErrorMessage ?? "Cannot delete description type.");
        }
        _deleting = false;
        _confirmDeleteHidden = true;
    }
}
