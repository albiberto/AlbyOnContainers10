@*         if (_dt == null || _formIsGlobal) return; *@
@*         if (_selectedCategory?.Id == _originalCategoryId) return; *@
@* *@
@*         Guid? newCatId = _selectedCategory?.Id; *@
@* *@
@*         if (_originalCategoryId.HasValue) *@
@*         { *@
@*             var rmResp = await RemoveRuleClient.GetResponse<RemoveCategoryDescriptionRuleResult>(new RemoveCategoryDescriptionRule(_originalCategoryId.Value, _dt.Id)); *@
