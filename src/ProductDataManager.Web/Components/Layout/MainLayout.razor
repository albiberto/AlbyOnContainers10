@inherits LayoutComponentBase

<div class="pdm-header">
    <a href="/" class="pdm-header-brand">
        <div class="pdm-header-brand-icon">
            <FluentIcon Value="@(new Icons.Regular.Size20.Box())" Color="Color.Custom" CustomColor="#fff" />
        </div>
        <div>
            <div style="font-size: 1rem; font-weight: 600; letter-spacing: -0.01em;">Product Data Manager</div>
            <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--pdm-text-muted);">E-Commerce Catalog</div>
        </div>
    </a>
    <FluentSpacer />
    <AuthorizeView>
        <Authorized>
            <div style="display: flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: var(--pdm-radius-md);">
                <FluentPersona Name="@context.User.Identity?.Name"
                               ImageSize="28px" />
            </div>
        </Authorized>
        <NotAuthorized>
            <FluentButton Href="/login" Appearance="Appearance.Stealth"
                          IconStart="@(new Icons.Regular.Size16.Person())">
                Login
            </FluentButton>
        </NotAuthorized>
    </AuthorizeView>
</div>

<div class="pdm-content-wrapper">
    <nav class="pdm-sidebar">
        <div class="pdm-sidebar-section">
            <div class="pdm-sidebar-label">Navigation</div>

            <NavLink class="pdm-nav-item" href="/" Match="NavLinkMatch.All">
                <span class="pdm-nav-icon">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Home())" Color="Color.Custom" CustomColor="currentColor" />
                </span>
                Dashboard
            </NavLink>
        </div>

        <div class="pdm-sidebar-section">
            <div class="pdm-sidebar-label">Catalog</div>

            <NavLink class="pdm-nav-item" href="/categories">
                <span class="pdm-nav-icon">
                    <FluentIcon Value="@(new Icons.Regular.Size20.FolderMultiple())" Color="Color.Custom" CustomColor="currentColor" />
                </span>
                Categories
            </NavLink>

            <NavLink class="pdm-nav-item" href="/products">
                <span class="pdm-nav-icon">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Box())" Color="Color.Custom" CustomColor="currentColor" />
                </span>
                Products
            </NavLink>
        </div>

        <div class="pdm-sidebar-section">
            <div class="pdm-sidebar-label">Configuration</div>

            <NavLink class="pdm-nav-item" href="/description-types">
                <span class="pdm-nav-icon">
                    <FluentIcon Value="@(new Icons.Regular.Size20.TextDescription())" Color="Color.Custom" CustomColor="currentColor" />
                </span>
                Description Types
            </NavLink>

            <NavLink class="pdm-nav-item" href="/attribute-types">
                <span class="pdm-nav-icon">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Tag())" Color="Color.Custom" CustomColor="currentColor" />
                </span>
                Attribute Types
            </NavLink>
        </div>
    </nav>

    <main class="pdm-main-content">
        @Body
    </main>
</div>

<FluentToastProvider />
<FluentDialogProvider />
<FluentMessageBarProvider />
