modules = ["dotnet-7.0", "web", "dotnet-10.0", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "ASPNETCORE_ENVIRONMENT=Development ASPNETCORE_URLS=http://0.0.0.0:5000 PATH=/nix/store/5hfn7q3adjwa8dh4yhhw1ip8njcbs7vs-dotnet-sdk-wrapped-10.0.101/bin:$PATH dotnet run --project src/ProductInformationManager.Web/ProductInformationManager.Web.csproj"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "export PATH=/nix/store/5hfn7q3adjwa8dh4yhhw1ip8njcbs7vs-dotnet-sdk-wrapped-10.0.101/bin:$PATH && ASPNETCORE_URLS=http://0.0.0.0:5000 dotnet /home/runner/workspace/publish/ProductInformationManager.Web.dll"]
build = ["bash", "-c", "export PATH=/nix/store/5hfn7q3adjwa8dh4yhhw1ip8njcbs7vs-dotnet-sdk-wrapped-10.0.101/bin:$PATH && dotnet publish src/ProductInformationManager.Web/ProductInformationManager.Web.csproj -c Release -o /home/runner/workspace/publish"]
